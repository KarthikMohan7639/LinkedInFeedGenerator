{
  "manifest_version": 3,
  "name": "LinkedIn Data Feed Generator",
  "version": "2.0.0",
  "description": "Captures LinkedIn post screenshots, extracts contacts via OCR, manages client outreach via Gmail and Google Sheets",
  "permissions": [
    "identity",
    "storage",
    "alarms",
    "tabs",
    "scripting",
    "activeTab",
    "offscreen"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://sheets.googleapis.com/*",
    "https://gmail.googleapis.com/*",
    "https://www.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/feed/*", "https://www.linkedin.com/search/*"],
      "js": ["content/linkedin_scraper.js"],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}
